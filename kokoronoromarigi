<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>心の止まり木：ココ</title>
    <style>
        :root {
            --bg-pink: #FFEBEE;
            --app-bg: #FFF3E0;
            --main-text: #5D4037;
            --accent-yellow: #FFE082;
            --nav-active: #FF8A80;
            --white: #ffffff;
            --coco-eye: #333;
            --coco-beak: #FFA726;
            --memo-bg: #E3F2FD;
            
            /* 感情の色 */
            --color-happy: #FFF176; /* ☀️ */
            --color-normal: #B0BEC5; /* ☁️ */
            --color-sad: #90CAF9;   /* ☔️ */
            --color-angry: #EF9A9A; /* ⚡️ */
        }

        * { box-sizing: border-box; }

        body {
            margin: 0; padding: 0;
            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
            background-color: var(--bg-pink);
            color: var(--main-text);
            display: flex; justify-content: center; align-items: center;
            height: 100vh; width: 100vw; overflow: hidden;
        }

        .app-container {
            width: 100%; max-width: 375px;
            height: 100vh;
            max-height: 100vh;
            background-color: var(--app-bg);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            display: flex; flex-direction: column;
            position: relative;
        }

        .header {
            padding: 12px; text-align: center; font-weight: bold; font-size: 1rem;
            background-color: var(--white); border-bottom: 1px solid #FFCDD2; flex-shrink: 0;
            z-index: 20;
        }

        .screen-container { 
            flex: 1; 
            overflow: hidden;
            position: relative; 
            display: flex; 
            flex-direction: column; 
        }
        
        .screen { 
            display: none; 
            height: 100%;
            flex-direction: column; 
            animation: fadeIn 0.3s ease; 
        }
        .screen.active { display: flex; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        #home-screen, #calendar-screen {
            padding: 15px;
            overflow-y: auto;
        }

        /* --- ココのアニメーション --- */
        #home-screen { align-items: center; justify-content: flex-start; text-align: center; }
        .coco-wrapper { position: relative; display: flex; flex-direction: column; align-items: center; margin-bottom: 15px; transform: scale(0.85); margin-top: 20px; }
        .coco-body {
            width: 120px; height: 105px; background-color: white; border-radius: 50% 50% 45% 45%;
            position: relative; z-index: 2; box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            animation: float-and-sway 4s ease-in-out infinite; display: flex; justify-content: center; align-items: center;
        }
        .eyes { display: flex; gap: 32px; position: absolute; top: 45%; left: 50%; transform: translate(-50%, -50%); transition: all 0.3s; }
        .eye { width: 8px; height: 8px; background-color: var(--coco-eye); border-radius: 50%; transition: all 0.3s; position: relative; }
        .eye.sad { height: 3px; border-radius: 2px; transform: translateY(3px); }
        .eye.happy::before {
            content: ''; position: absolute; top: -5px; left: -2px; width: 12px; height: 8px;
            border-top: 3px solid var(--coco-eye); border-radius: 50% 50% 0 0;
        }
        .eye.happy { background: transparent; }
        .beak { width: 0; height: 0; border-left: 6px solid transparent; border-right: 6px solid transparent; border-top: 8px solid var(--coco-beak); position: absolute; top: 55%; left: 50%; transform: translateX(-50%); }
        .cheeks { display: flex; gap: 65px; position: absolute; top: 55%; left: 50%; transform: translateX(-50%); }
        .cheek { width: 16px; height: 8px; background-color: #FFDDEE; border-radius: 50%; filter: blur(2px); opacity: 0.6; }
        .wing { width: 25px; height: 38px; background-color: #eee; border-radius: 50%; position: absolute; top: 40%; z-index: 1; }
        .wing.left { left: -10px; transform: rotate(30deg); }
        .wing.right { right: -10px; transform: rotate(-30deg); }
        @keyframes float-and-sway { 0%, 100% { transform: translateY(0px) rotate(0deg); } 50% { transform: translateY(-12px) rotate(2deg); } }

        /* --- カレンダー --- */
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; background: white; padding: 10px; border-radius: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-weight: bold; }
        .day-label { font-size: 0.7rem; text-align: center; color: #999; padding-bottom: 5px; }
        .day-cell { aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 0.8rem; cursor: pointer; border-radius: 8px; position: relative; transition: background 0.2s; }
        .day-cell:hover { background: #FFF9C4; }
        .day-cell.today { font-weight: bold; color: var(--nav-active); border: 1px solid var(--nav-active); }
        .mood-dot { width: 8px; height: 8px; border-radius: 50%; position: absolute; bottom: 3px; }

        /* --- トーク画面 --- */
        #chat-screen { padding: 0; display: none; }
        #chat-screen.active { display: flex; }
        .chat-container { 
            flex: 1; display: flex; flex-direction: column; gap: 12px; padding: 15px; overflow-y: auto; 
            background-color: var(--app-bg);
        }
        .chat-bubble { max-width: 85%; padding: 10px 14px; border-radius: 15px; font-size: 0.9rem; line-height: 1.4; position: relative; }
        .chat-bubble.coco { align-self: flex-start; background: white; border-bottom-left-radius: 2px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        .chat-bubble.user { align-self: flex-end; background: #FFCCBC; border-bottom-right-radius: 2px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }

        .chat-input-area { 
            width: 100%; padding: 10px; display: flex; gap: 8px; background: white; border-top: 1px solid #FFCDD2; flex-shrink: 0;
        }
        .chat-input-area input { flex: 1; padding: 10px 15px; border: 1px solid #ddd; border-radius: 20px; outline: none; font-size: 0.95rem; }
        .chat-input-area button { background: var(--accent-yellow); border: none; padding: 0 20px; border-radius: 20px; font-weight: bold; color: var(--main-text); cursor: pointer; }

        /* --- モーダル --- */
        .modal-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; display: none; align-items: center; justify-content: center; }
        .modal-content { background: white; width: 90%; max-height: 85%; padding: 20px; border-radius: 20px; overflow-y: auto; position: relative; }
        
        .history-item { border-left: 3px solid var(--accent-yellow); padding-left: 10px; margin-bottom: 12px; font-size: 0.85rem; }
        .question-card { background: #F5F5F5; border-radius: 10px; padding: 12px; margin-top: 10px; border: 1px solid #E0E0E0; }
        .feedback-input { width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 5px; margin-top: 8px; font-size: 0.8rem; }
        .save-btn { background: var(--nav-active); color: white; border: none; padding: 5px 12px; border-radius: 5px; margin-top: 8px; cursor: pointer; font-size: 0.8rem; }

        /* --- ナビ --- */
        .nav-bar { height: 65px; background: white; display: flex; border-top: 1px solid #FFCDD2; flex-shrink: 0; }
        .nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 0.65rem; color: #BBB; cursor: pointer; }
        .nav-item span { font-size: 1.3rem; margin-bottom: 2px; }
        .nav-item.active { color: var(--nav-active); font-weight: bold; }

        .emotion-buttons { display: flex; gap: 10px; justify-content: center; margin: 15px 0; }
        .emotion-btn { background: white; border: 2px solid transparent; font-size: 1.2rem; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .emotion-btn.selected { border-color: var(--nav-active); background-color: #FFF9C4; transform: scale(1.1); }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="header" id="header-title">心の止まり木：ココ</div>

        <div class="screen-container">
            <div id="home-screen" class="screen active">
                <div class="coco-wrapper">
                    <div class="coco-body">
                        <div class="wing left"></div><div class="wing right"></div>
                        <div class="eyes" id="coco-eyes"><div class="eye"></div><div class="eye"></div></div>
                        <div class="beak"></div>
                        <div class="cheeks"><div class="cheek"></div><div class="cheek"></div></div>
                    </div>
                </div>
                <div style="background:white; padding:15px; border-radius:15px; font-size:0.9rem; margin-bottom:15px; box-shadow:0 2px 5px rgba(0,0,0,0.05); width: 90%;">
                    ココだよ！今日はどんな一日だった？<br>今の気持ちに一番近い色を選んでね。
                </div>
                <div class="emotion-buttons">
                    <button class="emotion-btn" onclick="saveMood('happy', this)">☀️</button>
                    <button class="emotion-btn" onclick="saveMood('normal', this)">☁️</button>
                    <button class="emotion-btn" onclick="saveMood('sad', this)">☔️</button>
                    <button class="emotion-btn" onclick="saveMood('angry', this)">⚡️</button>
                </div>
                <button onclick="changeScreen('chat')" style="background:var(--accent-yellow); border:none; padding:12px 30px; border-radius:25px; font-weight:bold; cursor:pointer; width:80%; margin-top:10px;">おしゃべりする</button>
            </div>

            <div id="calendar-screen" class="screen">
                <div class="calendar-header">
                    <button onclick="moveMonth(-1)" style="border:none; background:none; cursor:pointer; padding: 10px;">◀</button>
                    <span id="current-month">2023年 10月</span>
                    <button onclick="moveMonth(1)" style="border:none; background:none; cursor:pointer; padding: 10px;">▶</button>
                </div>
                <div class="calendar-grid" id="calendar-grid"></div>
            </div>

            <div id="chat-screen" class="screen">
                <div class="chat-container" id="chat-logs"></div>
                <div class="chat-input-area">
                    <input type="text" id="user-input" placeholder="メッセージを入力..." onkeypress="if(event.key==='Enter') sendMessage()">
                    <button onclick="sendMessage()">送信</button>
                </div>
            </div>
        </div>

        <div class="nav-bar">
            <div class="nav-item active" id="nav-home" onclick="changeScreen('home')"><span>🏠</span>ホーム</div>
            <div class="nav-item" id="nav-calendar" onclick="changeScreen('calendar')"><span>📅</span>カレンダー</div>
            <div class="nav-item" id="nav-chat" onclick="changeScreen('chat')"><span>💬</span>トーク</div>
        </div>
    </div>

    <div class="modal-overlay" id="modal">
        <div class="modal-content">
            <h4 id="modal-date" style="margin-top:0; border-bottom:1px solid #EEE; padding-bottom:10px;">日付</h4>
            <div id="modal-mood-tag" style="margin:10px 0; font-weight:bold; color:var(--nav-active);"></div>
            <div style="margin-top:15px;">
                <h5 style="margin-bottom:8px;">💡 話したことリスト</h5>
                <div id="modal-history-list"></div>
            </div>
            <div style="margin-top:20px;" id="modal-question-section">
                <h5 style="margin-bottom:8px;">📋 先輩に聞くことメモ</h5>
                <div id="modal-question-list"></div>
            </div>
            <button onclick="closeModal()" style="width:100%; padding:12px; border-radius:10px; border:none; background:#EEE; cursor:pointer; margin-top:20px; font-weight:bold;">閉じる</button>
        </div>
    </div>

    <script>
        const apiKey = "";
        let moodData = JSON.parse(localStorage.getItem('coco_mood_data')) || {};
        let currentViewDate = new Date();

        function saveToStorage() { localStorage.setItem('coco_mood_data', JSON.stringify(moodData)); }
        function getTodayStr() { return new Date().toISOString().split('T')[0]; }

        function saveMood(mood, btn) {
            const dateStr = getTodayStr();
            if(!moodData[dateStr]) moodData[dateStr] = { mood: '', topics: [], questions: [] };
            moodData[dateStr].mood = mood;
            saveToStorage();
            document.querySelectorAll('.emotion-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
        }

        function renderCalendar() {
            const grid = document.getElementById('calendar-grid');
            const monthDisplay = document.getElementById('current-month');
            grid.innerHTML = '';
            const year = currentViewDate.getFullYear();
            const month = currentViewDate.getMonth();
            monthDisplay.innerText = `${year}年 ${month + 1}月`;
            ['日','月','火','水','木','金','土'].forEach(l => grid.innerHTML += `<div class="day-label">${l}</div>`);
            const firstDay = new Date(year, month, 1).getDay();
            const lastDate = new Date(year, month + 1, 0).getDate();
            for(let i=0; i<firstDay; i++) grid.innerHTML += '<div></div>';
            for(let d=1; d<=lastDate; d++) {
                const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
                const data = moodData[dateStr];
                let dot = data && data.mood ? `<div class="mood-dot" style="background:var(--color-${data.mood})"></div>` : '';
                grid.innerHTML += `<div class="day-cell" onclick="showDetail('${dateStr}')">${d}${dot}</div>`;
            }
        }

        function moveMonth(dir) { currentViewDate.setMonth(currentViewDate.getMonth() + dir); renderCalendar(); }

        function showDetail(dateStr) {
            const data = moodData[dateStr];
            document.getElementById('modal-date').innerText = dateStr.replace(/-/g, '/');
            const historyList = document.getElementById('modal-history-list');
            const questionList = document.getElementById('modal-question-list');
            const moodTag = document.getElementById('modal-mood-tag');

            if(data) {
                const icons = { happy:'☀️ 楽しい一日', normal:'☁️ 普通な気分', sad:'☔️ 悲しい・疲れ', angry:'⚡️ ぷんぷん' };
                moodTag.innerText = icons[data.mood] || '気分は未入力';
                historyList.innerHTML = data.topics.map(t => `<div class="history-item">${t}</div>`).join('') || '<p>記録なし</p>';
                questionList.innerHTML = data.questions.map((q, i) => `
                    <div class="question-card">
                        <div>Q: ${q.q}</div>
                        ${q.a ? `<div style="color:green; margin-top:5px;">Ans: ${q.a}</div>` : 
                        `<input type="text" class="feedback-input" id="f-${dateStr}-${i}"><button class="save-btn" onclick="saveFeedback('${dateStr}',${i})">保存</button>`}
                    </div>
                `).join('') || '<p>なし</p>';
            }
            document.getElementById('modal').style.display = 'flex';
        }

        function saveFeedback(d, i) {
            const v = document.getElementById(`f-${d}-${i}`).value;
            if(!v) return;
            moodData[d].questions[i].a = v;
            saveToStorage(); showDetail(d);
        }

        function closeModal() { document.getElementById('modal').style.display = 'none'; }

        async function sendMessage() {
            const input = document.getElementById('user-input');
            const text = input.value.trim();
            if(!text) return;
            input.value = '';
            addBubble('user', text);

            const systemPrompt = `あなたはシマエナガの「ココ」。新入社員の悩みを優しく聞き、癒やしのアドバイスをします。
            
            【重要：質問抽出のルール】
            ユーザーの話から「解決策」を提示する際、以下の基準で仕分けしてください：

            1. ココが解決すること（質問ノートに載せない）：
               - 「やる気が出ない」「自信がない」「緊張する」などのメンタル面。
               - 「早起きのコツ」「メモの取り方」などの一般的な仕事術。
               - これらは共感し、ココなりに優しくアドバイスして会話を完結させてください。

            2. 先輩に聞くべきこと（「★質問：」として抽出する）：
               - その職場独自の「暗黙のルール」「具体的な手順」「専門用語」。
               - 「これ、誰に承認もらえばいいの？」といった権限に関わること。
               - 「このツールのログイン方法がわからない」といった物理的な不明点。
               - これらだけを「★質問：[内容]」という形式で文末に1つだけ書いてください。

            【出力形式】
            - 返答は共感たっぷりに。
            - 話の内容を「● [内容]」という形式で要約して含めてください。`;

            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: text }] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });
                const data = await response.json();
                const reply = data.candidates?.[0]?.content?.parts?.[0]?.text || "そばにいるよ。";
                addBubble('coco', reply);

                const dateStr = getTodayStr();
                if(!moodData[dateStr]) moodData[dateStr] = { mood: 'normal', topics: [], questions: [] };

                const foundTopics = reply.match(/●\s*(.+)/g);
                if(foundTopics) {
                    foundTopics.forEach(t => {
                        const cleanT = t.replace('●', '').trim();
                        if(!moodData[dateStr].topics.includes(cleanT)) moodData[dateStr].topics.push(cleanT);
                    });
                }

                if(reply.includes('★質問：')) {
                    const q = reply.split('★質問：')[1].split('\n')[0].trim();
                    if(!moodData[dateStr].questions.find(item => item.q === q)) {
                        moodData[dateStr].questions.push({ q: q, a: '' });
                    }
                }
                saveToStorage();
            } catch(e) { addBubble('coco', "エラーになっちゃった。"); }
        }

        function addBubble(role, text) {
            const logs = document.getElementById('chat-logs');
            const b = document.createElement('div');
            b.className = `chat-bubble ${role}`;
            b.innerText = text;
            logs.appendChild(b);
            logs.scrollTop = logs.scrollHeight;
        }

        function changeScreen(name) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById(`${name}-screen`).classList.add('active');
            document.getElementById(`nav-${name}`).classList.add('active');
            if(name === 'calendar') renderCalendar();
            if(name === 'chat') document.getElementById('chat-logs').scrollTop = document.getElementById('chat-logs').scrollHeight;
        }

        window.onload = () => { renderCalendar(); addBubble('coco', "今日もお疲れ様。ココに何でも話してね。"); };
    </script>
</body>
</html>
